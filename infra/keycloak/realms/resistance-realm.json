{
  "realm": "resistance",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "resistance-api",
      "name": "Resistance API",
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "bearerOnly": false,
      "redirectUris": ["*"]
    },
    {
      "clientId": "resistance-mobile",
      "name": "Resistance Mobile",
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": [
        "http://localhost:7357/callback"
      ],
      "webOrigins": [
        "http://localhost:7357"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "roles": {
    "realm": [
      { "name": "USER" },
      { "name": "SUPERADMIN" }
    ]
  }
}
